@top Program { newline* (statement newline+)* statement? }

statement { (Track | Label | Instruction) }

Instruction { Opcode Operand+ }

Track { "TRACK" Label }

Operand { Instrument | Register | Value | Identifier }

Value { Immediate | Memory }

@tokens {
	Opcode { "PLAY" | "REST" | "JUMP" | "JMPZ" | "LOAD" | "STORE" | "ADD" }
	Instrument { "DRUMS" | "SYNTH" }
	Register { "BPM" | "VOL" | "REG" @digit+ }
	Label { Identifier ":" }
	Immediate { number }
	Memory { "[" (number | Register) "]" }
	Identifier { @asciiLetter+ @digit* }
	number { "-"? @digit+ }
	space { $[ \t\r]+ }
	newline { "\n" }
	Comment { ";" ![\n]* }
	@precedence { Opcode, Instrument, Register, Label, Identifier, Immediate, Memory }
}

@skip { space | Comment }
